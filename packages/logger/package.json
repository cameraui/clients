{
  "name": "@camera.ui/logger",
  "version": "0.0.3",
  "description": "camera.ui logging utility",
  "author": "seydx (https://github.com/cameraui/clients)",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && vite build",
    "format": "prettier --write 'src/' --ignore-unknown --no-error-on-unmatched-pattern",
    "lint": "eslint --fix .",
    "install-updates": "npm i --save",
    "prepublishOnly": "npm i --package-lock-only && npm run lint && npm run format && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "update": "updates --update ./"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "9.39.2",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.63.0",
    "unplugin-dts": "^1.0.3",
    "updates": "^17.18.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "bugs": {
    "url": "https://github.com/cameraui/clients/issues"
  },
  "homepage": "https://github.com/cameraui/clients/tree/main/packages/logger#readme",
  "keywords": [
    "camera.ui",
    "logger",
    "logging",
    "debug"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameraui/clients.git",
    "directory": "packages/logger"
  }
}
