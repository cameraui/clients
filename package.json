{
  "name": "@camera.ui/clients-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "camera.ui clients monorepo",
  "type": "module",
  "workspaces": [
    "packages/*",
    "clients/browser"
  ],
  "scripts": {
    "build:externals": "npm --prefix externals/rpc/node ci --ignore-scripts && npm --prefix externals/rpc/node run build && npm --prefix externals/sdk/node ci --ignore-scripts && npm --prefix externals/sdk/node run build",
    "build": "npm run build:externals && npm run build -w @camera.ui/transport && npm run build -w @camera.ui/browser",
    "release": "bash scripts/release.sh",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present"
  },
  "homepage": "https://github.com/cameraui/clients#readme",
  "bugs": {
    "url": "https://github.com/cameraui/clients/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameraui/clients.git"
  },
  "license": "MIT",
  "author": "seydx",
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "9.39.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "updates": "^17.18.0"
  }
}
