{
  "name": "@camera.ui/clients-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "camera.ui clients monorepo",
  "type": "module",
  "workspaces": [
    "packages/*",
    "clients/browser"
  ],
  "scripts": {
    "audit": "npm audit fix && npm audit fix --workspaces",
    "build": "npm run build -w @camera.ui/logger && npm run build -w @camera.ui/transport && npm run build -w @camera.ui/browser",
    "format": "npm run format --workspaces --if-present",
    "install-updates": "npm i --save",
    "lint": "npm run lint --workspaces --if-present",
    "release": "bash scripts/release.sh",
    "test": "npm run test --workspaces --if-present",
    "update": "updates --update ./ && npm run update --workspaces --if-present"
  },
  "homepage": "https://github.com/cameraui/clients#readme",
  "bugs": {
    "url": "https://github.com/cameraui/clients/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameraui/clients.git"
  },
  "license": "MIT",
  "author": "seydx",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vue/language-core": "^3.3.5",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "updates": "^17.18.1"
  },
  "overrides": {
    "@vue/language-core": "$@vue/language-core"
  }
}
